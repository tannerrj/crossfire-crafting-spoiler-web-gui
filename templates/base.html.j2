<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Crossfire Recipes{% endblock %}</title>
  <style>
    /* ── Reset & base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #0e1117;
      --surface:     #1a1f2e;
      --surface2:    #242938;
      --border:      #2e3550;
      --accent:      #4e9af1;
      --accent2:     #7c6af4;
      --text:        #d4daf0;
      --text-muted:  #6b7494;
      --green:       #4caf7d;
      --purple:      #b06af4;
      --gold:        #f0b429;
      --red:         #e05c5c;
      --radius:      8px;
      --radius-lg:   14px;
      --shadow:      0 2px 12px rgba(0,0,0,.45);
    }

    body {
      font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.6;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; color: #79b8ff; }

    /* ── Layout ──────────────────────────────────────────────── */
    header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow);
    }

    header .site-title {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--accent);
      white-space: nowrap;
    }

    header nav {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    header nav a {
      font-size: 0.82rem;
      padding: 0.3rem 0.75rem;
      border-radius: 20px;
      border: 1px solid var(--border);
      color: var(--text-muted);
      transition: all .15s;
    }
    header nav a:hover,
    header nav a.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
      text-decoration: none;
    }

    main {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1.25rem;
    }

    /* ── Cards ───────────────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      box-shadow: var(--shadow);
    }

    /* ── Badges ──────────────────────────────────────────────── */
    .badge {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 600;
      padding: 0.18rem 0.6rem;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: .04em;
    }
    .badge-alchemy    { background: #1a2e3a; color: #4dd0e1; border: 1px solid #4dd0e1; }
    .badge-woodsman   { background: #1a2e1f; color: #81c784; border: 1px solid #81c784; }
    .badge-thaumaturgy{ background: #2a1a3a; color: #ce93d8; border: 1px solid #ce93d8; }
    .badge-smithery   { background: #2e2010; color: #ffb74d; border: 1px solid #ffb74d; }
    .badge-jeweler    { background: #2e1a1a; color: #f48fb1; border: 1px solid #f48fb1; }
    .badge-bowyer     { background: #1a2a1a; color: #aed581; border: 1px solid #aed581; }
    .badge-default    { background: #1e1e2e; color: var(--text-muted); border: 1px solid var(--border); }

    /* ── Stat pills ──────────────────────────────────────────── */
    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin: 0.75rem 0;
    }
    .stat {
      display: flex;
      flex-direction: column;
      align-items: center;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.4rem 0.9rem;
      min-width: 80px;
    }
    .stat-label {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--text-muted);
    }
    .stat-value {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--gold);
    }
  </style>
  {% block extra_head %}{% endblock %}
</head>
<body>

<header>
  <span class="site-title">⚗ Crossfire Recipes</span>
  <nav>
    <a href="index.html">All&nbsp;(A–Z)</a>
    <a href="by_exp.html">By&nbsp;Exp</a>
    <a href="by_difficulty.html">By&nbsp;Difficulty</a>
    <a href="by_skill.html">By&nbsp;Skill</a>
  </nav>
</header>

<main>
  {% block content %}{% endblock %}
</main>

</body>
</html>
