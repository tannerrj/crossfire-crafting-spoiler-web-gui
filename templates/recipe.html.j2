{% extends "base.html.j2" %}

{% block title %}{{ recipe.name }} — Crossfire Recipes{% endblock %}

{% block extra_head %}
<style>
  /* ── Page header ─────────────────────────────────────────── */
  .recipe-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .recipe-header h1 {
    font-size: 1.6rem;
    color: var(--text);
    flex: 1 1 200px;
  }

  /* ── Two-column layout ───────────────────────────────────── */
  .recipe-body {
    display: grid;
    grid-template-columns: minmax(260px, 380px) 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 720px) {
    .recipe-body { grid-template-columns: 1fr; }
  }

  /* ── Info table inside the left card ─────────────────────── */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.75rem;
  }
  .info-table td {
    padding: 0.45rem 0.6rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.88rem;
    vertical-align: top;
  }
  .info-table td:first-child {
    color: var(--text-muted);
    white-space: nowrap;
    width: 1%;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: .05em;
    padding-right: 1.1rem;
  }
  .info-table tr:last-child td { border-bottom: none; }

  /* ── Ingredient list ─────────────────────────────────────── */
  .ingred-list {
    list-style: none;
    margin-top: 0.5rem;
  }
  .ingred-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .ingred-list li:last-child { border-bottom: none; }
  .ingred-count {
    min-width: 2.2rem;
    text-align: right;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--gold);
    font-size: 0.95rem;
  }
  .ingred-name a { color: var(--green); }
  .ingred-name a:hover { color: #a5d6a7; }

  /* ── Used by list ────────────────────────────────────────── */
  .used-by-list {
    list-style: none;
    margin-top: 0.5rem;
  }
  .used-by-list li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .used-by-list li:last-child { border-bottom: none; }
  .used-by-list a { color: var(--purple); }
  .used-by-list a:hover { color: #ce93d8; }

  /* ── Section headings inside cards ──────────────────────── */
  .card-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  /* ── SVG graph card ──────────────────────────────────────── */
  .graph-card {
    overflow: hidden;
  }
  .graph-card svg {
    width: 100%;
    height: auto;
    max-height: 520px;
    display: block;
  }
  /* Recolour graphviz SVG elements to fit dark theme */
  .graph-card svg text { fill: var(--text) !important; }
  .graph-card svg [fill="black"]  { fill: var(--accent)  !important; }
  .graph-card svg [fill="green"]  { fill: var(--green)   !important; }
  .graph-card svg [fill="purple"] { fill: var(--purple)  !important; }
  .graph-card svg [stroke="black"]  { stroke: var(--border)  !important; }
  .graph-card svg polygon { fill: var(--surface2) !important; stroke: var(--border) !important; }
  .graph-card svg ellipse { fill: var(--surface2) !important; stroke: var(--accent) !important; }
  /* edge arrows */
  .graph-card svg path { stroke: var(--text-muted) !important; }

  /* stub-item notice (ingredient-only entries with no recipe data) */
  .stub-notice {
    color: var(--text-muted);
    font-style: italic;
    margin-top: 1rem;
    font-size: 0.9rem;
  }
</style>
{% endblock %}

{% block content %}
<div class="recipe-header">
  <h1>{{ recipe.name }}</h1>
  {% if recipe.skill is defined %}
  <span class="badge badge-{{ recipe.skill|lower|replace(' ','_') if recipe.skill|lower in ['alchemy','woodsman','thaumaturgy','smithery','jeweler','bowyer'] else 'default' }}">
    {{ recipe.skill }}
  </span>
  {% endif %}
</div>

{% if recipe.Ingred is defined %}
{# ── Full recipe entry ────────────────────────────────── #}
<div class="recipe-body">

  {# Left column: details + ingredients + used-by #}
  <div style="display:flex; flex-direction:column; gap:1.25rem;">

    <div class="card">
      <p class="card-title">Details</p>
      {% if recipe.Exp is defined or recipe.Difficulty is defined or recipe.yield is defined %}
      <div class="stats">
        {% if recipe.Exp is defined %}
        <div class="stat">
          <span class="stat-label">Exp</span>
          <span class="stat-value">{{ "{:,}".format(recipe.Exp) }}</span>
        </div>
        {% endif %}
        {% if recipe.Difficulty is defined %}
        <div class="stat">
          <span class="stat-label">Difficulty</span>
          <span class="stat-value">{{ recipe.Difficulty }}</span>
        </div>
        {% endif %}
        {% if recipe.Exp is defined and recipe.Difficulty is defined and recipe.Difficulty > 0 %}
        <div class="stat">
          <span class="stat-label">Exp/Diff</span>
          <span class="stat-value">{{ "%.0f"|format(recipe.Exp / recipe.Difficulty) }}</span>
        </div>
        {% endif %}
        {% if recipe.yield is defined and recipe.yield > 1 %}
        <div class="stat">
          <span class="stat-label">Yield</span>
          <span class="stat-value">{{ recipe.yield }}</span>
        </div>
        {% endif %}
      </div>
      {% endif %}

      <table class="info-table">
        {% if recipe.Cauldron is defined %}
        <tr><td>Equipment</td><td>{{ recipe.Cauldron }}</td></tr>
        {% endif %}
        {% if recipe.chance is defined %}
        <tr><td>Book&nbsp;chance</td><td>{{ recipe.chance }}</td></tr>
        {% endif %}
        {% if recipe.ingred_price is defined %}
        <tr><td>Ingredient&nbsp;cost</td><td>{{ "{:,}".format(recipe.ingred_price) }}</td></tr>
        {% endif %}
        {% if recipe.result_price is defined %}
        <tr><td>Result&nbsp;value</td><td>{{ "{:,}".format(recipe.result_price) }}</td></tr>
        {% endif %}
        {% if recipe.ingred_price is defined and recipe.result_price is defined and recipe.ingred_price > 0 %}
        <tr>
          <td>Profit</td>
          <td style="color: {% if recipe.result_price > recipe.ingred_price %}var(--green){% else %}var(--red){% endif %}">
            {{ "{:,}".format(recipe.result_price - recipe.ingred_price) }}
          </td>
        </tr>
        {% endif %}
      </table>
    </div>

    <div class="card">
      <p class="card-title">Ingredients</p>
      <ul class="ingred-list">
        {% for ing in recipe.Ingred %}
        <li>
          <span class="ingred-count">{{ ing.count }}×</span>
          <span class="ingred-name">
            <a href="{{ ing.nameHash }}.html">{{ ing.name }}</a>
          </span>
        </li>
        {% endfor %}
      </ul>
    </div>

    {% if recipe.ancestors is defined and recipe.ancestors %}
    <div class="card">
      <p class="card-title">Used as ingredient in</p>
      <ul class="used-by-list">
        {% for anc in recipe.ancestors %}
        <li><a href="{{ anc.nameHash }}.html">{{ anc.name }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

  </div>

  {# Right column: dependency graph #}
  {% if svg_content %}
  <div class="card graph-card">
    <p class="card-title">Dependency graph</p>
    {{ svg_content | safe }}
  </div>
  {% endif %}

</div>

{% else %}
{# ── Ingredient-only stub page ─────────────────────────── #}
<div class="card" style="max-width: 560px;">
  <p class="stub-notice">
    <strong>{{ recipe.name }}</strong> is an ingredient — it has no recipe of its own in this dataset.
  </p>

  {% if recipe.ancestors is defined and recipe.ancestors %}
  <br>
  <p class="card-title">Used as ingredient in</p>
  <ul class="used-by-list">
    {% for anc in recipe.ancestors %}
    <li><a href="{{ anc.nameHash }}.html">{{ anc.name }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if recipe.minimum is defined %}
  <br>
  <p style="font-size:0.85rem; color:var(--text-muted);">
    Minimum quantity required across all uses: <strong style="color:var(--gold)">{{ recipe.minimum }}</strong>
  </p>
  {% endif %}
</div>
{% endif %}
{% endblock %}
