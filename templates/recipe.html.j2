{% extends "base.html.j2" %}

{% block title %}{{ recipe.name }} — Crossfire Recipes{% endblock %}

{% block extra_head %}
<style>
  /* ── Page header ─────────────────────────────────────────── */
  .recipe-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .recipe-header h1 {
    font-size: 1.6rem;
    color: var(--text);
    flex: 1 1 200px;
  }

  /* ── Info table (Details card) ───────────────────────────── */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.75rem;
  }
  .info-table td {
    padding: 0.45rem 0.6rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.88rem;
    vertical-align: top;
  }
  .info-table td:first-child {
    color: var(--text-muted);
    white-space: nowrap;
    width: 1%;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: .05em;
    padding-right: 1.1rem;
  }
  .info-table tr:last-child td { border-bottom: none; }

  /* ── Ingredient list ─────────────────────────────────────── */
  .ingred-list {
    list-style: none;
    margin-top: 0.5rem;
  }
  .ingred-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .ingred-list li:last-child { border-bottom: none; }
  .ingred-count {
    min-width: 2.2rem;
    text-align: right;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--gold);
    font-size: 0.95rem;
  }
  .ingred-name a { color: var(--green); }
  .ingred-name a:hover { color: #a5d6a7; }

  /* ── Section headings inside cards ──────────────────────── */
  .card-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  /* ── SVG graph card (full-width, top) ───────────────────── */
  .graph-card {
    overflow: hidden;
    margin-bottom: 1.25rem;
  }
  .graph-card .graph-viewport {
    overflow: hidden;
    width: 100%;
    height: 420px;
    cursor: grab;
    position: relative;
    touch-action: none;
  }
  .graph-card .graph-viewport.panning { cursor: grabbing; }
  .graph-card svg {
    width: 100%;
    height: 100%;
    display: block;
    transform-origin: 0 0;
    user-select: none;
  }
  .graph-zoom-hint {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: right;
    margin-top: 0.35rem;
    letter-spacing: .03em;
  }
  /* Recolour graphviz SVG elements to fit dark theme */
  .graph-card svg text { fill: var(--text) !important; }
  .graph-card svg [fill="black"]  { fill: var(--accent)  !important; }
  .graph-card svg [fill="green"]  { fill: var(--green)   !important; }
  .graph-card svg [fill="purple"] { fill: var(--purple)  !important; }
  .graph-card svg [stroke="black"]  { stroke: var(--border)  !important; }
  .graph-card svg polygon { fill: var(--surface2) !important; stroke: var(--border) !important; }
  .graph-card svg ellipse { fill: var(--surface2) !important; stroke: var(--accent) !important; }
  .graph-card svg path { stroke: var(--text-muted) !important; }

  /* ── Lower two-column row (Details | Ingredients) ────────── */
  .recipe-lower {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 640px) {
    .recipe-lower { grid-template-columns: 1fr; }
  }

  /* ── Used-as-ingredient section (full width, multi-column) ── */
  .used-by-section { }
  .skill-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1.25rem;
    margin-top: 0.75rem;
  }
  .skill-col-heading {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text-muted);
    font-weight: 600;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.35rem;
  }
  .skill-col-list {
    list-style: none;
  }
  .skill-col-list li {
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.88rem;
  }
  .skill-col-list li:last-child { border-bottom: none; }
  .skill-col-list a { color: var(--purple); }
  .skill-col-list a:hover { color: #ce93d8; }

  /* stub-item notice (ingredient-only entries with no recipe data) */
  .stub-notice {
    color: var(--text-muted);
    font-style: italic;
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  /* used-by list for stub pages */
  .used-by-list {
    list-style: none;
    margin-top: 0.5rem;
  }
  .used-by-list li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .used-by-list li:last-child { border-bottom: none; }
  .used-by-list a { color: var(--purple); }
  .used-by-list a:hover { color: #ce93d8; }
</style>
{% endblock %}

{% block content %}
<div class="recipe-header">
  <h1>{{ recipe.name }}</h1>
  {% if recipe.skill is defined %}
  <span class="badge badge-{{ recipe.skill|lower|replace(' ','_') if recipe.skill|lower in ['alchemy','woodsman','thaumaturgy','smithery','jeweler','bowyer'] else 'default' }}">
    {{ recipe.skill }}
  </span>
  {% endif %}
</div>

{% if recipe.Ingred is defined %}
{# ── Full recipe entry ────────────────────────────────── #}

{# Dependency graph — full width at the top #}
{% if svg_content %}
<div class="card graph-card">
  <p class="card-title">Dependency graph</p>
  <div class="graph-viewport" id="graph-viewport">
    {{ svg_content | safe }}
  </div>
  <p class="graph-zoom-hint">Scroll to zoom · Drag to pan · Double-click to reset</p>
</div>
{% endif %}

{# Details (left) and Ingredients (right) #}
<div class="recipe-lower">

  <div class="card">
    <p class="card-title">Details</p>
    {% if recipe.Exp is defined or recipe.Difficulty is defined or recipe.yield is defined %}
    <div class="stats">
      {% if recipe.Exp is defined %}
      <div class="stat">
        <span class="stat-label">Exp</span>
        <span class="stat-value">{{ "{:,}".format(recipe.Exp) }}</span>
      </div>
      {% endif %}
      {% if recipe.Difficulty is defined %}
      <div class="stat">
        <span class="stat-label">Difficulty</span>
        <span class="stat-value">{{ recipe.Difficulty }}</span>
      </div>
      {% endif %}
      {% if recipe.Exp is defined and recipe.Difficulty is defined and recipe.Difficulty > 0 %}
      <div class="stat">
        <span class="stat-label">Exp/Diff</span>
        <span class="stat-value">{{ "%.0f"|format(recipe.Exp / recipe.Difficulty) }}</span>
      </div>
      {% endif %}
      {% if recipe.yield is defined and recipe.yield > 1 %}
      <div class="stat">
        <span class="stat-label">Yield</span>
        <span class="stat-value">{{ recipe.yield }}</span>
      </div>
      {% endif %}
    </div>
    {% endif %}

    <table class="info-table">
      {% if recipe.Cauldron is defined %}
      <tr><td>Equipment</td><td>{{ recipe.Cauldron }}</td></tr>
      {% endif %}
      {% if recipe.chance is defined %}
      <tr><td>Book&nbsp;chance</td><td>{{ recipe.chance }}</td></tr>
      {% endif %}
      {% if recipe.ingred_price is defined %}
      <tr><td>Ingredient&nbsp;cost</td><td>{{ "{:,}".format(recipe.ingred_price) }}</td></tr>
      {% endif %}
      {% if recipe.result_price is defined %}
      <tr><td>Result&nbsp;value</td><td>{{ "{:,}".format(recipe.result_price) }}</td></tr>
      {% endif %}
      {% if recipe.ingred_price is defined and recipe.result_price is defined and recipe.ingred_price > 0 %}
      <tr>
        <td>Profit</td>
        <td style="color: {% if recipe.result_price > recipe.ingred_price %}var(--green){% else %}var(--red){% endif %}">
          {{ "{:,}".format(recipe.result_price - recipe.ingred_price) }}
        </td>
      </tr>
      {% endif %}
    </table>
  </div>

  <div class="card">
    <p class="card-title">Ingredients</p>
    <ul class="ingred-list">
      {% for ing in recipe.Ingred %}
      <li>
        <span class="ingred-count">{{ ing.count }}×</span>
        <span class="ingred-name">
          <a href="{{ ing.nameHash }}.html">{{ ing.name }}</a>
        </span>
      </li>
      {% endfor %}
    </ul>
  </div>

</div>

{# Used as ingredient in — full width, grouped by skill #}
{% if recipe.ancestors is defined and recipe.ancestors %}
{% set skill_order = ['alchemy','bowyer','jeweler','smithery','thaumaturgy','woodsman'] %}
{# Collect unique skills from ancestors, preserving preferred order then alphabetical for unknowns #}
{% set ns = namespace(by_skill={}) %}
{% for anc in recipe.ancestors %}
  {% set sk = anc.skill if anc.skill else 'other' %}
  {% if sk not in ns.by_skill %}
    {% set _ = ns.by_skill.update({sk: []}) %}
  {% endif %}
  {% set _ = ns.by_skill[sk].append(anc) %}
{% endfor %}
<div class="card used-by-section">
  <p class="card-title">Used as ingredient in</p>
  <div class="skill-columns">
    {% for sk in skill_order %}
      {% if sk in ns.by_skill %}
      <div>
        <p class="skill-col-heading">{{ sk|capitalize }}</p>
        <ul class="skill-col-list">
          {% for anc in ns.by_skill[sk] %}
          <li><a href="{{ anc.nameHash }}.html">{{ anc.name }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    {% endfor %}
    {% for sk, items in ns.by_skill.items() %}
      {% if sk not in skill_order %}
      <div>
        <p class="skill-col-heading">{{ sk|capitalize }}</p>
        <ul class="skill-col-list">
          {% for anc in items %}
          <li><a href="{{ anc.nameHash }}.html">{{ anc.name }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

{% else %}
{# ── Ingredient-only stub page ─────────────────────────── #}
<div class="card" style="max-width: 560px;">
  <p class="stub-notice">
    <strong>{{ recipe.name }}</strong> is an ingredient — it has no recipe of its own in this dataset.
  </p>

  {% if recipe.ancestors is defined and recipe.ancestors %}
  <br>
  <p class="card-title">Used as ingredient in</p>
  <ul class="used-by-list">
    {% for anc in recipe.ancestors %}
    <li><a href="{{ anc.nameHash }}.html">{{ anc.name }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if recipe.minimum is defined %}
  <br>
  <p style="font-size:0.85rem; color:var(--text-muted);">
    Minimum quantity required across all uses: <strong style="color:var(--gold)">{{ recipe.minimum }}</strong>
  </p>
  {% endif %}
</div>
{% endif %}

{% if svg_content %}
<script>
(function () {
  var vp  = document.getElementById('graph-viewport');
  if (!vp) return;
  var svg = vp.querySelector('svg');
  if (!svg) return;

  var scale = 1, tx = 0, ty = 0;
  var dragging = false, startX, startY, startTx, startTy;
  var lastDist = null;

  function clampAndApply() {
    svg.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')';
  }

  /* ── scroll to zoom ── */
  vp.addEventListener('wheel', function (e) {
    e.preventDefault();
    var rect   = vp.getBoundingClientRect();
    var mx     = e.clientX - rect.left;
    var my     = e.clientY - rect.top;
    var factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
    var newScale = Math.min(Math.max(scale * factor, 0.2), 8);
    tx = mx - (mx - tx) * (newScale / scale);
    ty = my - (my - ty) * (newScale / scale);
    scale = newScale;
    clampAndApply();
  }, { passive: false });

  /* ── drag to pan ── */
  vp.addEventListener('mousedown', function (e) {
    if (e.button !== 0) return;
    dragging = true; startX = e.clientX; startY = e.clientY;
    startTx = tx; startTy = ty;
    vp.classList.add('panning');
  });
  window.addEventListener('mousemove', function (e) {
    if (!dragging) return;
    tx = startTx + (e.clientX - startX);
    ty = startTy + (e.clientY - startY);
    clampAndApply();
  });
  window.addEventListener('mouseup', function () {
    dragging = false;
    vp.classList.remove('panning');
  });

  /* ── double-click to reset ── */
  vp.addEventListener('dblclick', function () {
    scale = 1; tx = 0; ty = 0;
    clampAndApply();
  });

  /* ── pinch to zoom (touch) ── */
  vp.addEventListener('touchstart', function (e) {
    if (e.touches.length === 2) {
      lastDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
    } else if (e.touches.length === 1) {
      dragging = true;
      startX = e.touches[0].clientX; startY = e.touches[0].clientY;
      startTx = tx; startTy = ty;
    }
  }, { passive: true });
  vp.addEventListener('touchmove', function (e) {
    if (e.touches.length === 2 && lastDist !== null) {
      e.preventDefault();
      var dist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      var mx = (e.touches[0].clientX + e.touches[1].clientX) / 2 - vp.getBoundingClientRect().left;
      var my = (e.touches[0].clientY + e.touches[1].clientY) / 2 - vp.getBoundingClientRect().top;
      var newScale = Math.min(Math.max(scale * (dist / lastDist), 0.2), 8);
      tx = mx - (mx - tx) * (newScale / scale);
      ty = my - (my - ty) * (newScale / scale);
      scale = newScale;
      lastDist = dist;
      clampAndApply();
    } else if (e.touches.length === 1 && dragging) {
      tx = startTx + (e.touches[0].clientX - startX);
      ty = startTy + (e.touches[0].clientY - startY);
      clampAndApply();
    }
  }, { passive: false });
  vp.addEventListener('touchend', function () {
    lastDist = null; dragging = false;
  });
})();
</script>
{% endif %}
{% endblock %}
